                                </svg></div>
                              <div class="button-text">
{{ block.settings.text_button_tekst }}
</div>
                              <div class="cart-icon-button w-embed"><svg id="cart" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 19.467 16.872">
