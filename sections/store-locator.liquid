<div class="store-locator">
  <div class="store-locator__search">
    <input type="text" id="store-search" placeholder="Zoek op stad of postcode..." autocomplete="off" />
    <button id="locate-me">📍 Gebruik mijn locatie</button>
  </div>

  <div class="store-locator__layout">
    <div class="store-locator__list" id="store-list">
      <div class="store-locator__count" id="store-count"></div>
      <div id="stores-container"></div>
    </div>
    <div class="store-locator__map" id="map"></div>
  </div>
</div>

<style>
  .store-locator {
    font-family: inherit;
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
  }

  .store-locator__search {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
  }

  .store-locator__search input {
    flex: 1;
    padding: 12px 16px;
    font-size: 16px;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    outline: none;
    transition: border-color 0.2s;
  }

  .store-locator__search input:focus {
    border-color: #f5a623;
  }

  #locate-me {
    padding: 12px 20px;
    background: #f5a623;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }

  #locate-me:hover {
    background: #e0921a;
  }

  .store-locator__layout {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 20px;
    height: 600px;
  }

  .store-locator__list {
    overflow-y: auto;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    background: #fff;
  }

  .store-locator__count {
    padding: 12px 16px;
    font-size: 13px;
    color: #888;
    border-bottom: 1px solid #f0f0f0;
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 1;
  }

  .store-card {
    padding: 14px 16px;
    border-bottom: 1px solid #f0f0f0;
    cursor: pointer;
    transition: background 0.15s;
  }

  .store-card:hover,
  .store-card.active {
    background: #fff8ee;
  }

  .store-card__name {
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 4px;
    color: #222;
  }

  .store-card__address {
    font-size: 13px;
    color: #666;
    margin-bottom: 8px;
  }

  .store-card__distance {
    font-size: 12px;
    color: #f5a623;
    font-weight: 600;
    margin-bottom: 6px;
  }

  .store-card__directions {
    display: inline-block;
    font-size: 12px;
    color: #f5a623;
    text-decoration: none;
    border: 1px solid #f5a623;
    padding: 4px 10px;
    border-radius: 4px;
    transition: all 0.2s;
  }

  .store-card__directions:hover {
    background: #f5a623;
    color: white;
  }

  .store-locator__map {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #e0e0e0;
  }

  #map {
    width: 100%;
    height: 100%;
  }

  .store-locator__empty {
    padding: 40px 20px;
    text-align: center;
    color: #999;
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .store-locator__layout {
      grid-template-columns: 1fr;
      grid-template-rows: 300px 400px;
      height: auto;
    }

    .store-locator__list {
      order: 2;
    }

    .store-locator__map {
      order: 1;
    }

    .store-locator__search {
      flex-direction: column;
    }
  }
</style>

