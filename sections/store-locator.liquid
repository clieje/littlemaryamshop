 "address": "Zandberg 4", "city": "Zevenbergen"}, {"name": "Jumbo Zevenhuizen Dorpsstraat", "address": "Dorpsstraat 129", "city": "Zevenhuizen"}, {"name": "Jumbo Zoetermeer Groenblauwlaan", "address": "Groenblauwlaan 109", "city": "Zoetermeer"}, {"name": "Jumbo Zoetermeer Kentgensplein", "address": "Kentgensplein 3", "city": "Zoetermeer"}, {"name": "Jumbo Zoetermeer Meeuwenveld", "address": "Meeuwenveld 8", "city": "Zoetermeer"}, {"name": "Jumbo Zoetermeer Middelwaard", "address": "Middelwaard 52", "city": "Zoetermeer"}, {"name": "Jumbo Zoetermeer Oosterheemplein", "address": "Oosterheemplein 548", "city": "Zoetermeer"}, {"name": "Jumbo Zoetermeer Quirinegang", "address": "Quirinegang 201", "city": "Zoetermeer"}, {"name": "Jumbo Zoeterwoude Dorpsstraat", "address": "Dorpsstraat 34", "city": "Zoeterwoude"}, {"name": "Jumbo Zoeterwoude Molenplein", "address": "Molenplein 1", "city": "Zoeterwoude"}, {"name": "Jumbo Zuidlaren Stationsweg", "address": "Stationsweg 8", "city": "Zuidlaren"}, {"name": "Jumbo Zuidwolde Wethouder Klunders", "address": "Wethouder Klunderstraat 16", "city": "Zuidwolde"}, {"name": "Jumbo Zutphen Rudolf Steinerlaan", "address": "Rudolf Steinerlaan 47", "city": "Zutphen"}, {"name": "Jumbo Zutphen Ruys de Beerenbrouck", "address": "Ruys de Beerenbrouckstraat 14", "city": "Zutphen"}, {"name": "Jumbo Zwaagdijk", "address": "Zwaagdijk 227F", "city": "Zwaagdijk"}, {"name": "Jumbo Zwijndrecht Brabant", "address": "Brabant 1", "city": "Zwijndrecht"}, {"name": "Jumbo Zwijndrecht Kort Ambachtlaan", "address": "Kort Ambachtlaan 97", "city": "Zwijndrecht"}, {"name": "Jumbo Zwolle Assendorperstraat", "address": "Assendorperstraat 71", "city": "Zwolle"}, {"name": "Jumbo Zwolle Bachplein", "address": "Bachplein 14", "city": "Zwolle"}, {"name": "Jumbo Zwolle de Dobbe", "address": "De Dobbe 3", "city": "Zwolle"}, {"name": "Jumbo Zwolle Hogenkampspassage", "address": "Hogenkampspassage 10", "city": "Zwolle"}, {"name": "Jumbo Zwolle Sellekamp", "address": "Sellekamp 26", "city": "Zwolle"}, {"name": "Jumbo Zwolle Veemarkt", "address": "Veemarkt 20", "city": "Zwolle"}, {"name": "Jumbo Zwolle Wade", "address": "Wade 102", "city": "Zwolle"}];

  const MAPS_API_KEY = 'YOUR_GOOGLE_MAPS_API_KEY'; // vervang dit met jouw API key

  let map, markers = [], infoWindow, geocoder;
  let userLat = null, userLng = null;
  let filteredStores = [...STORES];
  let activeCard = null;

  function getDistance(lat1, lng1, lat2, lng2) {
    const R = 6371;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLng = (lng2 - lng1) * Math.PI / 180;
    const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLng/2)**2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  }

  function getMapsUrl(store) {
    return `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(store.address + ', ' + store.city + ', Nederland')}`;
  }

  function renderStores(stores) {
    const container = document.getElementById('stores-container');
    const count = document.getElementById('store-count');
    count.textContent = `${stores.length} winkel${stores.length !== 1 ? 's' : ''} gevonden`;

    if (stores.length === 0) {
      container.innerHTML = '<div class="store-locator__empty">Geen winkels gevonden. Probeer een andere zoekopdracht.</div>';
      return;
    }

    container.innerHTML = stores.map((store, i) => `
      <div class="store-card" data-index="${i}" onclick="selectStore(${i})">
        <div class="store-card__name">${store.name}</div>
        <div class="store-card__address">${store.address}, ${store.city}</div>
        ${store.distance !== undefined ? `<div class="store-card__distance">${store.distance.toFixed(1)} km</div>` : ''}
        <a class="store-card__directions" href="${getMapsUrl(store)}" target="_blank" onclick="event.stopPropagation()">📍 Routebeschrijving</a>
      </div>
    `).join('');
  }

  function selectStore(index) {
    const store = filteredStores[index];
    if (!store.lat) return;

    // highlight card
    document.querySelectorAll('.store-card').forEach(c => c.classList.remove('active'));
    const card = document.querySelector(`.store-card[data-index="${index}"]`);
    if (card) { card.classList.add('active'); card.scrollIntoView({behavior: 'smooth', block: 'nearest'}); }

    // pan map
    map.panTo({lat: store.lat, lng: store.lng});
    map.setZoom(15);

    // open infowindow
    if (infoWindow) infoWindow.close();
    infoWindow = new google.maps.InfoWindow({
      content: `<div style="font-family:inherit;padding:4px"><strong>${store.name}</strong><br>${store.address}, ${store.city}<br><a href="${getMapsUrl(store)}" target="_blank" style="color:#f5a623">Routebeschrijving →</a></div>`
    });
    if (markers[index]) infoWindow.open(map, markers[index]);
  }

  function filterStores(query) {
    const q = query.toLowerCase().trim();
    filteredStores = q
      ? STORES.filter(s => s.city.toLowerCase().includes(q) || s.address.toLowerCase().includes(q) || s.name.toLowerCase().includes(q))
      : [...STORES];

    if (userLat !== null) {
      filteredStores.forEach(s => {
        if (s.lat) s.distance = getDistance(userLat, userLng, s.lat, s.lng);
      });
      filteredStores.sort((a, b) => (a.distance || 9999) - (b.distance || 9999));
    }

    renderStores(filteredStores);
    updateMarkers();
  }

  function updateMarkers() {
    markers.forEach(m => m && m.setMap(null));
    markers = [];

    filteredStores.forEach((store, i) => {
      if (!store.lat) return;
      const marker = new google.maps.Marker({
        position: {lat: store.lat, lng: store.lng},
        map,
        title: store.name,
        icon: { url: 'https://maps.google.com/mapfiles/ms/icons/red-dot.png' }
      });
      marker.addListener('click', () => selectStore(i));
      markers[i] = marker;
    });
  }

  function geocodeStores() {
    // Geocode stores in batches using Maps Geocoding API
    let i = 0;
    function next() {
      if (i >= STORES.length) { renderStores(filteredStores); updateMarkers(); return; }
      const store = STORES[i];
      geocoder.geocode({address: `${store.address}, ${store.city}, Nederland`}, (results, status) => {
        if (status === 'OK') {
          store.lat = results[0].geometry.location.lat();
          store.lng = results[0].geometry.location.lng();
        }
        i++;
        setTimeout(next, 50); // stay within rate limits
      });
    }
    next();
  }

  function initMap() {
    geocoder = new google.maps.Geocoder();
    map = new google.maps.Map(document.getElementById('map'), {
      center: {lat: 52.1326, lng: 5.2913},
      zoom: 8,
      styles: [{featureType:'poi',elementType:'labels',stylers:[{visibility:'off'}]}]
    });

    renderStores(filteredStores);
    geocodeStores();

    document.getElementById('store-search').addEventListener('input', e => filterStores(e.target.value));

    document.getElementById('locate-me').addEventListener('click', () => {
      if (!navigator.geolocation) return alert('Geolocatie wordt niet ondersteund door deze browser.');
      navigator.geolocation.getCurrentPosition(pos => {
        userLat = pos.coords.latitude;
        userLng = pos.coords.longitude;
        map.panTo({lat: userLat, lng: userLng});
        map.setZoom(12);
        new google.maps.Marker({
          position: {lat: userLat, lng: userLng},
          map,
          title: 'Jouw locatie',
          icon: {url: 'https://maps.google.com/mapfiles/ms/icons/blue-dot.png'}
        });
        filterStores(document.getElementById('store-search').value);
      }, () => alert('Kon locatie niet ophalen.'));
    });
  }

  // Load Google Maps
  (function() {
    const script = document.createElement('script');
    script.src = `https://maps.googleapis.com/maps/api/js?key=${MAPS_API_KEY}&callback=initMap`;
    script.async = true;
    script.defer = true;
    document.head.appendChild(script);
    window.initMap = initMap;
  })();
</script>

