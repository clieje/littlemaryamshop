<div class="lm-locator">
  <div class="lm-locator__search-bar">
    <div class="lm-locator__search-wrap">
      <svg class="lm-locator__search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="lm-search" placeholder="{{ 'sections.store_locator.search_placeholder' | t }}" autocomplete="off" />
    </div>
    <button id="lm-locate">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>
      {{ 'sections.store_locator.my_location' | t }}
    </button>
  </div>
  <div class="lm-locator__body">
    <div class="lm-locator__sidebar">
      <div class="lm-locator__count" id="lm-count"></div>
      <div class="lm-locator__list" id="lm-list"></div>
    </div>
    <div class="lm-locator__map-wrap">
      <div id="lm-map"></div>
    </div>
  </div>
</div>

<style>
  :root {
    --lm-green:       #1d6b40;
    --lm-green-dark:  #134d2d;
    --lm-green-light: #e8f4ee;
    --lm-yellow:      #FFFE05;
    --lm-yellow-dark: #FFFE05;
    --lm-cream:       #f5f0e8;
    --lm-cream-dark:  #ece5d8;
    --lm-text:        #1a2e1f;
    --lm-text-light:  #5a7060;
    --lm-white:       #ffffff;
    --lm-radius:      14px;
    --lm-shadow:      0 4px 24px rgba(29,107,64,0.10);
  }

  .lm-locator {
    background: var(--lm-cream);
    border-radius: 24px;
    padding: 40px 36px 36px;
    max-width: 1200px;
    margin: 0 auto;
    font-family: 'Baukasten', sans-serif;
  }

  .lm-locator__search-bar { display: flex; gap: 12px; margin-bottom: 24px; }

  .lm-locator__search-wrap { flex: 1; position: relative; }

  .lm-locator__search-icon {
    position: absolute; left: 16px; top: 50%; transform: translateY(-50%);
    color: var(--lm-green); pointer-events: none;
  }

  #lm-search {
    width: 100%; padding: 14px 16px 14px 46px;
    font-family: 'Baukasten', sans-serif; font-size: 15px;
    border: 2px solid var(--lm-cream-dark); border-radius: var(--lm-radius);
    background: var(--lm-white); color: var(--lm-text);
    outline: none; box-sizing: border-box;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  #lm-search:focus { border-color: var(--lm-green); box-shadow: 0 0 0 3px rgba(29,107,64,0.12); }
  #lm-search::placeholder { color: var(--lm-text-light); }

  #lm-locate {
    display: flex; align-items: center; gap: 8px;
    padding: 14px 22px; background: var(--lm-green); color: var(--lm-white);
    border: none; border-radius: var(--lm-radius);
    font-family: 'Baukasten', sans-serif; font-size: 15px; font-weight: 600;
    cursor: pointer; white-space: nowrap;
    transition: background 0.2s, transform 0.1s;
  }
  #lm-locate:hover { background: var(--lm-green-dark); transform: translateY(-1px); }

  .lm-locator__body {
    display: grid; grid-template-columns: 360px 1fr;
    gap: 20px; height: 580px;
  }

  .lm-locator__sidebar {
    display: flex; flex-direction: column;
    background: var(--lm-white); border-radius: var(--lm-radius);
    overflow: hidden; box-shadow: var(--lm-shadow);
    border: 1.5px solid var(--lm-cream-dark);
  }

  .lm-locator__count {
    padding: 12px 16px; font-family: 'Baukasten', sans-serif;
    font-size: 12px; font-weight: 700; color: var(--lm-text-light);
    text-transform: uppercase; letter-spacing: 0.08em;
    border-bottom: 1.5px solid var(--lm-cream-dark);
    background: var(--lm-cream); flex-shrink: 0;
  }

  .lm-locator__list { overflow-y: auto; flex: 1; }
  .lm-locator__list::-webkit-scrollbar { width: 5px; }
  .lm-locator__list::-webkit-scrollbar-thumb { background: var(--lm-cream-dark); border-radius: 99px; }

  .lm-store-card {
    padding: 14px 16px; border-bottom: 1.5px solid var(--lm-cream-dark);
    cursor: pointer; transition: background 0.15s;
  }
  .lm-store-card:last-child { border-bottom: none; }
  .lm-store-card:hover { background: var(--lm-green-light); }
  .lm-store-card.active { background: var(--lm-green-light); border-left: 4px solid var(--lm-green); padding-left: 12px; }

  .lm-store-card__name { font-family: 'Baukasten', sans-serif; font-weight: 700; font-size: 14px; color: var(--lm-green-dark); margin-bottom: 3px; }
  .lm-store-card__address { font-family: 'Baukasten', sans-serif; font-size: 13px; color: var(--lm-text-light); margin-bottom: 8px; }

  .lm-store-card__footer { display: flex; align-items: center; justify-content: space-between; }

  .lm-store-card__distance { font-family: 'College Star Full', 'Baukasten', sans-serif; font-size: 13px; color: var(--lm-green); font-weight: 700; }

  .lm-store-card__directions {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: 'Baukasten', sans-serif; font-size: 12px; font-weight: 700;
    color: var(--lm-green-dark); background: var(--lm-yellow);
    text-decoration: none; padding: 5px 12px; border-radius: 99px;
    transition: background 0.2s, transform 0.1s;
  }
  .lm-store-card__directions:hover { background: var(--lm-yellow-dark); transform: translateY(-1px); }

  .lm-locator__empty {
    padding: 48px 24px; text-align: center;
    color: var(--lm-text-light); font-family: 'Baukasten', sans-serif; font-size: 14px;
  }

  .lm-locator__map-wrap {
    border-radius: var(--lm-radius); overflow: hidden;
    box-shadow: var(--lm-shadow); border: 1.5px solid var(--lm-cream-dark);
  }
  #lm-map { width: 100%; height: 100%; }

  .lm-info-window { font-family: 'Baukasten', sans-serif; padding: 4px 2px; min-width: 180px; }
  .lm-info-window strong { display: block; color: var(--lm-green-dark); font-size: 14px; margin-bottom: 4px; }
  .lm-info-window span { display: block; color: var(--lm-text-light); font-size: 12px; margin-bottom: 8px; }
  .lm-info-window a { display: inline-block; background: var(--lm-yellow); color: var(--lm-green-dark); font-weight: 700; font-size: 12px; padding: 5px 12px; border-radius: 99px; text-decoration: none; }

  @media (max-width: 820px) {
    .lm-locator { padding: 24px 16px 20px; border-radius: 16px; }
    .lm-locator__body { grid-template-columns: 1fr; grid-template-rows: 320px 380px; height: auto; }
    .lm-locator__map-wrap { order: -1; }
    .lm-locator__search-bar { flex-direction: column; }
    #lm-locate { justify-content: center; }
  }
</style>

