function lmSelect(idx){
  const s=lmFiltered[idx];
  document.querySelectorAll('.lm-store-card').forEach(c=>c.classList.remove('active'));
  const card=document.querySelector(`.lm-store-card[data-idx="${idx}"]`);
  if(card){card.classList.add('active');card.scrollIntoView({behavior:'smooth',block:'nearest'});}
  if(!s.lat)return;
  lmMap.panTo({lat:s.lat,lng:s.lng});lmMap.setZoom(15);
  lmMarkers.forEach((m,i)=>{if(m)m.setIcon(lmIcon(i===idx,lmFiltered[i]&&lmFiltered[i].chain));});
  if(lmInfoWindow)lmInfoWindow.close();
  lmInfoWindow=new google.maps.InfoWindow({content:`<div class="lm-info-window"><strong>${s.name}</strong><span>${s.address}, ${s.city}</span><a href="${lmUrl(s)}" target="_blank">${LM_I18N.directions}</a></div>`});
  if(lmMarkers[idx])lmInfoWindow.open(lmMap,lmMarkers[idx]);
}

let lmCluster=null;
function lmUpdateMarkers(){
  if(lmCluster){lmCluster.clearMarkers();lmCluster=null;}
  lmMarkers.forEach(m=>m&&m.setMap(null));lmMarkers=[];
  const newMarkers=[];
  lmFiltered.forEach((s,i)=>{
    if(!s.lat)return;
    const m=new google.maps.Marker({position:{lat:s.lat,lng:s.lng},title:s.name,icon:lmIcon(false,s.chain)});
    m.addListener('click',()=>lmSelect(i));
    lmMarkers[i]=m;newMarkers.push(m);
  });
  if(window.markerClusterer){
    lmCluster=new markerClusterer.MarkerClusterer({
      map:lmMap,markers:newMarkers,
      renderer:{render:({count,position})=>new google.maps.Marker({
        position,
        icon:{url:'data:image/svg+xml;charset=UTF-8,'+encodeURIComponent(`<svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 44 44"><circle cx="22" cy="22" r="22" fill="#1d6b40" opacity="0.9"/><circle cx="22" cy="22" r="16" fill="#FFFE05"/><text x="22" y="27" text-anchor="middle" font-family="sans-serif" font-size="13" font-weight="bold" fill="#1d6b40">${count}</text></svg>`),scaledSize:new google.maps.Size(44,44),anchor:new google.maps.Point(22,22)},
        zIndex:1000
      })}
    });
  } else {
    newMarkers.forEach(m=>m.setMap(lmMap));
  }
}

function lmFilter(q){
  const query=q.toLowerCase().trim();
  lmFiltered=query?LM_STORES.filter(s=>s.city.toLowerCase().includes(query)||s.address.toLowerCase().includes(query)||s.name.toLowerCase().includes(query)):[...LM_STORES];
  if(lmUserLat!==null){lmFiltered.forEach(s=>{if(s.lat)s.distance=lmDist(lmUserLat,lmUserLng,s.lat,s.lng);});lmFiltered.sort((a,b)=>(a.distance||9999)-(b.distance||9999));}
  lmRender(lmFiltered);lmUpdateMarkers();
}

function lmGeocodeAll(){
  let i=0;
  function next(){
    if(i>=LM_STORES.length){lmRender(lmFiltered);lmUpdateMarkers();return;}
    const s=LM_STORES[i];
    if(s.lat){i++;setTimeout(next,10);return;}
    lmGeocoder.geocode({address:`${s.address}, ${s.city}, ${LM_I18N.geocodeCountry}`},(res,status)=>{
      if(status==='OK'){s.lat=res[0].geometry.location.lat();s.lng=res[0].geometry.location.lng();}
      i++;setTimeout(next,55);
    });
  }
  next();
}

function lmInitMap(){
  lmGeocoder=new google.maps.Geocoder();
  lmMap=new google.maps.Map(document.getElementById('lm-map'),{
    center:{lat:52.15,lng:5.38},zoom:7,styles:LM_MAP_STYLE,
    mapTypeControl:false,streetViewControl:false,fullscreenControl:false
  });
  lmRender(lmFiltered);
  lmUpdateMarkers();
  document.getElementById('lm-search').addEventListener('input',e=>lmFilter(e.target.value));
  document.getElementById('lm-locate').addEventListener('click',()=>{
    if(!navigator.geolocation)return;
    navigator.geolocation.getCurrentPosition(pos=>{
      lmUserLat=pos.coords.latitude;lmUserLng=pos.coords.longitude;
      lmMap.panTo({lat:lmUserLat,lng:lmUserLng});lmMap.setZoom(11);
      new google.maps.Marker({position:{lat:lmUserLat,lng:lmUserLng},map:lmMap,title:LM_I18N.yourLocation,
        icon:{url:'data:image/svg+xml;charset=UTF-8,'+encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20"><circle cx="10" cy="10" r="10" fill="#FFFE05" opacity=".4"/><circle cx="10" cy="10" r="6" fill="#1d6b40"/><circle cx="10" cy="10" r="3" fill="#FFFE05"/></svg>'),scaledSize:new google.maps.Size(20,20),anchor:new google.maps.Point(10,10)}});
      lmFilter(document.getElementById('lm-search').value);
    });
  });
}

(function(){
  const s=document.createElement('script');
  // Load MarkerClusterer first, then Maps API
  const mc=document.createElement('script');
  mc.src='https://unpkg.com/@googlemaps/markerclusterer/dist/index.min.js';
  mc.onload=function(){
    const s=document.createElement('script');
    s.src=`https://maps.googleapis.com/maps/api/js?key=${LM_API_KEY}&callback=lmInitMap`;
    s.async=true;s.defer=true;document.head.appendChild(s);
  };
  document.head.appendChild(mc);
  s.async=true;s.defer=true;document.head.appendChild(s);
  window.lmInitMap=lmInitMap;
})();
</script>

