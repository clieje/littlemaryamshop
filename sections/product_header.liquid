<div class="padding_5">
          <div class="container-large big">
            <div class="product-header_component">
              {% unless template.name == 'index' %}    <ul li-unless="template.name == 'index'" role="list" class="breadcrumb">
    
                {% if template == 'product' %}    <li li-if="template == 'product'" class="breadcrum_item">
    
                  <a li-object:href="product.collections[0].url" href="{{ product.collections[0].url }}" class="w-inline-block">
                    <div li-object="product.collections[0].title" class="small-text">{{ product.collections[0].title }}</div>
                  </a><img src="{{ 'hartje_klein.png' | asset_url }}" loading="lazy" sizes="(max-width: 479px) 92vw, (max-width: 767px) 95vw, (max-width: 991px) 96vw, (max-width: 2472px) 98vw, 2423px" srcset="{{ 'hartje_klein-p-500.png' | asset_url }} 500w, {{ 'hartje_klein-p-800.png' | asset_url }} 800w, {{ 'hartje_klein-p-1080.png' | asset_url }} 1080w, {{ 'hartje_klein-p-1600.png' | asset_url }} 1600w, {{ 'hartje_klein-p-2000.png' | asset_url }} 2000w, {{ 'hartje_klein.png' | asset_url }} 2423w" alt="" class="hartje-kleinst">
                    </li>
{% endif %}
                {% if template == 'product' %}    <li li-if="template == 'product'" class="breadcrum_item">
    
                  <div li-object="product.title" class="small-text">{{ product.title }}</div>
                    </li>
{% endif %}
                  </ul>
{% endunless %}
              <script src="{{ 'li_custom.js' | asset_url }}" type="text/javascript"></script>
<div li-element="product-variant-container" class="w-layout-grid product-header_layout" x-data="handleVariant({{ product | json | escape }}, {{ product.options_by_name | json | escape }}, {{ product.selected_or_first_available_variant | json | escape }})" x-init="$nextTick(() => { activateVariants() })" @setbundleitem.window="updateBundleItem($event.detail.product, $event.detail.quantity)">
                <div id="w-node-fe548112-1dd8-9dee-4669-09e4aeb677a0-9580fc58" class="swiper-container is-product-gallery">
                  <div class="swiper is-product-gallery">
                    <div id="my-gallery" li-for:inside="media in product.media" class="swiper-wrapper is-product-gallery">
        {% for media in product.media %}                            
                      
                            {% if media.media_type == 'image' and forloop.first == false %}    <div li-if="media.media_type == 'image' and forloop.first == false" class="swiper-slide is-product-gallery">
    
                        <div class="product-header_gallery-lightbox-3"><img li-object:src="media | image_url: width: 1000" li-object:alt="media.alt" alt="{{ media.alt }}" src="{{ media | image_url: width: 1000 }}" loading="lazy" class="product-header_gallery-image-3"></div>
                          </div>
{% endif %}
                            
                      
                            {% if media.media_type == 'video' %}    <div li-if="media.media_type == 'video'" class="swiper-slide is-product-gallery">
    
                        <div class="product-header_gallery-lightbox-3">
                          <div li-object="media | video_tag: controls: true" class="product-header_gallery-image-3">{{ media | video_tag: controls: true }}</div>
                        </div>
                          </div>
{% endif %}
                            
                    
                    {% endfor %}    </div>
                  </div>
                  <div class="product-header_slider-wrapper-3">
                    <div class="swiper_button-wrapper is-product-slider pointer-events-off z-index-1 hide-mobile-landscape"></div>
                    <div class="swiper is-product-thumbnail">
                      <div li-for:inside="media in product.media" class="swiper-wrapper is-product-thumbnail _1">
        {% for media in product.media %}                            
                        
                            {% if media.media_type == 'image'  and forloop.first == false %}    <div li-if="media.media_type == 'image'  and forloop.first == false" class="swiper-slide is-product-thumbnail is-active">
    <img li-object:src="media | image_url: width: 200" li-object:alt="media.alt" alt="{{ media.alt }}" src="{{ media | image_url: width: 200 }}" loading="lazy" class="product-header_thumbnail-image-3">    </div>
{% endif %}
                            
                        
                            {% if media.media_type == 'video' %}    <div li-if="media.media_type == 'video'" class="swiper-slide is-product-thumbnail">
    <img li-object:src="media | image_url: width: 200" li-object:alt="media.alt" alt="{{ media.alt }}" src="{{ media | image_url: width: 200 }}" loading="lazy" class="product-header_thumbnail-image-3">
                          <div aria-hidden="true" class="product-header_play-icon w-embed"><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true" role="img" class="iconify iconify--ic" width="100%" height="100%" preserveaspectratio="xMidYMid meet" viewbox="0 0 24 24">
                              <path fill="currentColor" d="M8 5v14l11-7z"></path>
                            </svg></div>
                            </div>
{% endif %}
                            
                      
                    {% endfor %}    </div>
                    </div>
                  </div>
                  <div class="swiper-slide is-product-thumbnail is-active hide"></div>
                </div>
                <div li-cf-theme-blocks="theme" id="w-node-e206aa1f-c6a7-a112-f7c6-30bd6839644e-9580fc58" class="product-header_product-details">
{% content_for 'blocks' %}
</div>
              </div>
            </div>
          </div>
        </div>
        <div class="hide w-embed w-script">
          <script src="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js"></script>
          <script>
document.addEventListener("DOMContentLoaded", () => {
  $(".swiper-container").each(function (index) {
    const thumbsSwiper = new Swiper($(this).find(".swiper.is-product-thumbnail")[0], {
      slidesPerView: "auto",
      rewind: false,
      loopedSlides: 8,
      slideToClickedSlide: true,
      spaceBetween: "4%",
    });
    const swiper = new Swiper($(this).find(".swiper.is-product-gallery")[0], {
      mousewheel: {
        forceToAxis: true
      },
      thumbs: {
        swiper: thumbsSwiper,
        slideThumbActiveClass: "is-active",
      },
      keyboard: {
        enabled: true,
        onlyInViewport: true
      },
      navigation: {
        nextEl: $(this).find(".swiper-next")[0],
        prevEl: $(this).find(".swiper-prev")[0],
      }
    });
  }); 
});
</script>
        </div> {% schema %} {
    "tag": "section",
    "name": "Product Header",
    "class": "section_product-header",
    "blocks": [
        {
            "type": "@theme"
        },
        {
            "type": "@app"
        }
    ],
    "presets": [
        {
            "name": "Product Header",
            "category": "Liquify",
            "blocks": [
                {
                    "type": "product-name"
                },
                {
                    "type": "product-price"
                },
                {
                    "type": "description"
                },
                {
                    "type": "add-to-cart"
                }
            ]
        }
    ],
    "enabled_on": {
        "templates": [
            "product"
        ]
    }
} {% endschema %}