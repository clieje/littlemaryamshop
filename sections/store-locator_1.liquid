<div class="lm-locator">
  <div class="lm-locator__header">
    <h2 class="lm-locator__title">Winkelzoeker</h2>
    <p class="lm-locator__subtitle">Vind Little Maryam bij een Jumbo bij jou in de buurt</p>
  </div>
  <div class="lm-locator__search-bar">
    <div class="lm-locator__search-wrap">
      <svg class="lm-locator__search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="lm-search" placeholder="Zoek op stad of postcode..." autocomplete="off" />
    </div>
    <button id="lm-locate">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>
      Mijn locatie
    </button>
  </div>
  <div class="lm-locator__body">
    <div class="lm-locator__sidebar">
      <div class="lm-locator__count" id="lm-count"></div>
      <div class="lm-locator__list" id="lm-list"></div>
    </div>
    <div class="lm-locator__map-wrap">
      <div id="lm-map"></div>
    </div>
  </div>
</div>

<style>
  :root {
    --lm-green:       #1d6b40;
    --lm-green-dark:  #134d2d;
    --lm-green-light: #e8f4ee;
    --lm-yellow:      #fffe07;
    --lm-yellow-dark: #fffe07;
    --lm-cream:       #f5f0e8;
    --lm-cream-dark:  #ece5d8;
    --lm-text:        #1a2e1f;
    --lm-text-light:  #5a7060;
    --lm-white:       #ffffff;
    --lm-radius:      14px;
    --lm-shadow:      0 4px 24px rgba(29,107,64,0.10);
  }

  .lm-locator {
    background: var(--lm-cream);
    border-radius: 24px;
    padding: 40px 36px 36px;
    max-width: 1200px;
    margin: 0 auto;
    font-family: 'Baukasten', sans-serif;
  }

  .lm-locator__header { text-align: center; margin-bottom: 28px; }

  .lm-locator__title {
    font-family: 'Kandij DEMO', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--lm-green);
    margin: 0 0 8px;
    line-height: 1.1;
  }

  .lm-locator__subtitle {
    font-family: 'Baukasten', sans-serif;
    color: var(--lm-text-light);
    font-size: 16px;
    margin: 0;
  }

  .lm-locator__search-bar { display: flex; gap: 12px; margin-bottom: 24px; }

  .lm-locator__search-wrap { flex: 1; position: relative; }

  .lm-locator__search-icon {
    position: absolute; left: 16px; top: 50%; transform: translateY(-50%);
    color: var(--lm-green); pointer-events: none;
  }

  #lm-search {
    width: 100%; padding: 14px 16px 14px 46px;
    font-family: 'Baukasten', sans-serif; font-size: 15px;
    border: 2px solid var(--lm-cream-dark); border-radius: var(--lm-radius);
    background: var(--lm-white); color: var(--lm-text);
    outline: none; box-sizing: border-box;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  #lm-search:focus { border-color: var(--lm-green); box-shadow: 0 0 0 3px rgba(29,107,64,0.12); }
  #lm-search::placeholder { color: var(--lm-text-light); }

  #lm-locate {
    display: flex; align-items: center; gap: 8px;
    padding: 14px 22px; background: var(--lm-green); color: var(--lm-white);
    border: none; border-radius: var(--lm-radius);
    font-family: 'Baukasten', sans-serif; font-size: 15px; font-weight: 600;
    cursor: pointer; white-space: nowrap;
    transition: background 0.2s, transform 0.1s;
  }
  #lm-locate:hover { background: var(--lm-green-dark); transform: translateY(-1px); }

  .lm-locator__body {
    display: grid; grid-template-columns: 360px 1fr;
    gap: 20px; height: 580px;
  }

  .lm-locator__sidebar {
    display: flex; flex-direction: column;
    background: var(--lm-white); border-radius: var(--lm-radius);
    overflow: hidden; box-shadow: var(--lm-shadow);
    border: 1.5px solid var(--lm-cream-dark);
  }

  .lm-locator__count {
    padding: 12px 16px; font-family: 'Baukasten', sans-serif;
    font-size: 12px; font-weight: 700; color: var(--lm-text-light);
    text-transform: uppercase; letter-spacing: 0.08em;
    border-bottom: 1.5px solid var(--lm-cream-dark);
    background: var(--lm-cream); flex-shrink: 0;
  }

  .lm-locator__list { overflow-y: auto; flex: 1; }
  .lm-locator__list::-webkit-scrollbar { width: 5px; }
  .lm-locator__list::-webkit-scrollbar-thumb { background: var(--lm-cream-dark); border-radius: 99px; }

  .lm-store-card {
    padding: 14px 16px; border-bottom: 1.5px solid var(--lm-cream-dark);
    cursor: pointer; transition: background 0.15s;
  }
  .lm-store-card:last-child { border-bottom: none; }
  .lm-store-card:hover { background: var(--lm-green-light); }
  .lm-store-card.active { background: var(--lm-green-light); border-left: 4px solid var(--lm-green); padding-left: 12px; }

  .lm-store-card__name { font-family: 'Baukasten', sans-serif; font-weight: 700; font-size: 14px; color: var(--lm-green-dark); margin-bottom: 3px; }
  .lm-store-card__address { font-family: 'Baukasten', sans-serif; font-size: 13px; color: var(--lm-text-light); margin-bottom: 8px; }

  .lm-store-card__footer { display: flex; align-items: center; justify-content: space-between; }

  .lm-store-card__distance { font-family: 'College Star Full', 'Baukasten', sans-serif; font-size: 13px; color: var(--lm-green); font-weight: 700; }

  .lm-store-card__directions {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: 'Baukasten', sans-serif; font-size: 12px; font-weight: 700;
    color: var(--lm-green-dark); background: var(--lm-yellow);
    text-decoration: none; padding: 5px 12px; border-radius: 99px;
    transition: background 0.2s, transform 0.1s;
  }
  .lm-store-card__directions:hover { background: var(--lm-yellow-dark); transform: translateY(-1px); }

  .lm-locator__empty {
    padding: 48px 24px; text-align: center;
    color: var(--lm-text-light); font-family: 'Baukasten', sans-serif; font-size: 14px;
  }

  .lm-locator__map-wrap {
    border-radius: var(--lm-radius); overflow: hidden;
    box-shadow: var(--lm-shadow); border: 1.5px solid var(--lm-cream-dark);
  }
  #lm-map { width: 100%; height: 100%; }

  .lm-info-window { font-family: 'Baukasten', sans-serif; padding: 4px 2px; min-width: 180px; }
  .lm-info-window strong { display: block; color: var(--lm-green-dark); font-size: 14px; margin-bottom: 4px; }
  .lm-info-window span { display: block; color: var(--lm-text-light); font-size: 12px; margin-bottom: 8px; }
  .lm-info-window a { display: inline-block; background: var(--lm-yellow); color: var(--lm-green-dark); font-weight: 700; font-size: 12px; padding: 5px 12px; border-radius: 99px; text-decoration: none; }

  @media (max-width: 820px) {
    .lm-locator { padding: 24px 16px 20px; border-radius: 16px; }
    .lm-locator__body { grid-template-columns: 1fr; grid-template-rows: 320px 380px; height: auto; }
    .lm-locator__map-wrap { order: -1; }
    .lm-locator__search-bar { flex-direction: column; }
    #lm-locate { justify-content: center; }
  }
</style>

<script>
const LM_STORES = [{"name":"Jumbo Aalsmeer Ophelialaan","address":"Ophelialaan 124","city":"Aalsmeer"},{"name":"Jumbo Aalst Hortensialaan","address":"Hortensialaan 2","city":"Aalst"},{"name":"Jumbo Aalten Adm. de Ruyterstraat","address":"Admiraal de Ruyterstraat 10","city":"Aalten"},{"name":"Jumbo Alkmaar J. Naberstraat","address":"J. Naberstraat 49-51","city":"Alkmaar"},{"name":"Jumbo Alkmaar Muiderwaard","address":"Muiderwaard 416","city":"Alkmaar"},{"name":"Jumbo Alkmaar Paardenmarkt","address":"Paardenmarkt 2","city":"Alkmaar"},{"name":"Jumbo Alkmaar Winkelwaard","address":"Winkelwaard 486","city":"Alkmaar"},{"name":"Jumbo Almelo Bornerbroeksestraat","address":"Bornerbroeksestraat 79","city":"Almelo"},{"name":"Jumbo Almere Geinplein","address":"Geinplein 32-37","city":"Almere"},{"name":"Jumbo Almere-Buiten Detroitpad","address":"Detroitpad 1","city":"Almere"},{"name":"Jumbo Almere-Haven Jaagmeent","address":"Jaagmeent 250","city":"Almere-Haven"},{"name":"Jumbo Alphen aan den Rijn Herenhof","address":"Herenhof 183","city":"Alphen aan den Rijn"},{"name":"Jumbo Amerongen Koenestraat","address":"Koenestraat 36","city":"Amerongen"},{"name":"Jumbo Amersfoort Emiclaerhof","address":"Emiclaerhof 248","city":"Amersfoort"},{"name":"Jumbo Amersfoort Leusderweg","address":"Leusderweg 152","city":"Amersfoort"},{"name":"Jumbo Amersfoort Stastokerf","address":"Pieter Stastokerf 6-8","city":"Amersfoort"},{"name":"Jumbo Amersfoort Ursulapolder","address":"Paulinapolder 1","city":"Amersfoort"},{"name":"Jumbo Amersfoort Wiekslag","address":"Wiekslag 261","city":"Amersfoort"},{"name":"Jumbo Amersfoort Zonnewijzer","address":"Zonnewijzer 21","city":"Amersfoort"},{"name":"Jumbo Amstelveen Groenhof","address":"Groenhof 165","city":"Amstelveen"},{"name":"Jumbo Amstelveen Rembrandtweg","address":"Rembrandtweg 617-635","city":"Amstelveen"},{"name":"Jumbo Amsterdam Baarsjesweg","address":"Baarsjesweg 303-305","city":"Amsterdam"},{"name":"Jumbo Amsterdam Buikslotermeer","address":"Buikslotermeerplein 52","city":"Amsterdam"},{"name":"Jumbo Amsterdam Buitenvelderts","address":"Buitenveldertselaan 184","city":"Amsterdam"},{"name":"Jumbo Amsterdam Foodmarkt","address":"Gedempt Hamerkanaal 223","city":"Amsterdam"},{"name":"Jumbo Amsterdam Jodenbreestr","address":"Jodenbreestraat 11","city":"Amsterdam"},{"name":"Jumbo Amsterdam Julianaplein","address":"Julianaplein 48","city":"Amsterdam"},{"name":"Jumbo Amsterdam Kastelenstraat","address":"Kastelenstraat 70","city":"Amsterdam"},{"name":"Jumbo Amsterdam Linnaeusstraat","address":"Linnaeusstraat 245","city":"Amsterdam"},{"name":"Jumbo Amsterdam OostelijkeHandelsk","address":"Oostelijke Handelskade 1005","city":"Amsterdam"},{"name":"Jumbo Amsterdam Osdorpplein","address":"Osdorpplein 1014","city":"Amsterdam"},{"name":"Jumbo Amsterdam Pieter Calandlaan","address":"Pieter Calandlaan 808","city":"Amsterdam"},{"name":"Jumbo Amsterdam Plein 40-45","address":"Plein 40-45 12","city":"Amsterdam"},{"name":"Jumbo Amsterdam Reigersbos","address":"Reigersbos 196","city":"Amsterdam"},{"name":"Jumbo Amsterdam Teleportboulevard","address":"Teleportboulevard 78","city":"Amsterdam"},{"name":"Jumbo Amsterdam Wisseloord","address":"Wisseloord 126","city":"Amsterdam"},{"name":"Jumbo Anna Paulowna Molengang","address":"Molengang 10-14","city":"Anna Paulowna"},{"name":"Jumbo Apeldoorn De Eglantier","address":"De Eglantier 606","city":"Apeldoorn"},{"name":"Jumbo Apeldoorn Korianderplein","address":"Korianderplein 61","city":"Apeldoorn"},{"name":"Jumbo Apeldoorn Schubertplein","address":"Schubertplein 1-5","city":"Apeldoorn"},{"name":"Jumbo Arnhem Amsterdamseweg","address":"Amsterdamseweg 33","city":"Arnhem"},{"name":"Jumbo Arnhem Elderveldplein","address":"Elderveldplein 12","city":"Arnhem"},{"name":"Jumbo Arnhem Kronenburgpassage","address":"Kronenburgpassage 110","city":"Arnhem"},{"name":"Jumbo Arnhem Lelyweg","address":"Dr. C. Lelyweg 9-13","city":"Arnhem"},{"name":"Jumbo Arnhem Oostburgwal","address":"Oostburgwal 12","city":"Arnhem"},{"name":"Jumbo Assen Kleuvenstee","address":"Kleuvenstee 106","city":"Assen"},{"name":"Jumbo Assen Nijlandstraat","address":"Nijlandstraat 141","city":"Assen"},{"name":"Jumbo Assen Nobellaan","address":"Nobellaan 259","city":"Assen"},{"name":"Jumbo Barendrecht Onderlangs","address":"Onderlangs 44","city":"Barendrecht"},{"name":"Jumbo Barneveld Amersfoortsestraat","address":"Amersfoortsestraat 70","city":"Barneveld"},{"name":"Jumbo Breda Foodmarkt","address":"Rat Verleghstraat 4","city":"Breda"},{"name":"Jumbo Breda Dr. Struyckenplein","address":"Dr. Struyckenplein 60","city":"Breda"},{"name":"Jumbo Den Bosch Helftheuvelpassage","address":"Helftheuvelpassage 346","city":"Den Bosch"},{"name":"Jumbo Den Haag Anemoonstraat","address":"Anemoonstraat 4","city":"Den Haag"},{"name":"Jumbo Den Haag Leyweg","address":"Leyweg 918C","city":"Den Haag"},{"name":"Jumbo Eindhoven Belgieplein","address":"Belgieplein 21","city":"Eindhoven"},{"name":"Jumbo Eindhoven WC Woensel","address":"Winkelcentrum Woensel 1","city":"Eindhoven"},{"name":"Jumbo Groningen Foodmarkt","address":"Boumaboulevard 525","city":"Groningen"},{"name":"Jumbo Groningen Linnaeusplein","address":"Linnaeusplein 55","city":"Groningen"},{"name":"Jumbo Haarlem Engelenburg","address":"Engelenburg 70","city":"Haarlem"},{"name":"Jumbo Maastricht Mosae Forum","address":"Laag Mosae Forum 26","city":"Maastricht"},{"name":"Jumbo Nijmegen Fenikshof","address":"Fenikshof 3","city":"Nijmegen"},{"name":"Jumbo Rotterdam Botersloot","address":"Botersloot 13-19","city":"Rotterdam"},{"name":"Jumbo Rotterdam Hoogstraat","address":"Hoogstraat 1005","city":"Rotterdam"},{"name":"Jumbo Tilburg Foodmarkt","address":"Stappegoorweg 175","city":"Tilburg"},{"name":"Jumbo Utrecht Foodmarkt","address":"Brusselplein 15","city":"Utrecht"},{"name":"Jumbo Utrecht Biltstraat","address":"Biltstraat 74","city":"Utrecht"},{"name":"Jumbo Zwolle Bachplein","address":"Bachplein 14","city":"Zwolle"},{"name":"Jumbo Zwolle Veemarkt","address":"Veemarkt 20","city":"Zwolle"}];

const LM_API_KEY = 'YOUR_GOOGLE_MAPS_API_KEY';

const LM_MAP_STYLE = [
  {elementType:'geometry',stylers:[{color:'#f0ebe0'}]},
  {elementType:'labels.text.fill',stylers:[{color:'#1d6b40'}]},
  {elementType:'labels.text.stroke',stylers:[{color:'#f0ebe0'}]},
  {featureType:'administrative',elementType:'geometry.stroke',stylers:[{color:'#c5b89a'}]},
  {featureType:'landscape.natural',elementType:'geometry',stylers:[{color:'#dfd9c8'}]},
  {featureType:'poi',elementType:'geometry',stylers:[{color:'#c8d9b0'}]},
  {featureType:'poi',elementType:'labels.text.fill',stylers:[{color:'#2d5a35'}]},
  {featureType:'poi.park',elementType:'geometry.fill',stylers:[{color:'#b8d4a0'}]},
  {featureType:'road',elementType:'geometry',stylers:[{color:'#ffffff'}]},
  {featureType:'road.arterial',elementType:'geometry',stylers:[{color:'#f5e8c8'}]},
  {featureType:'road.highway',elementType:'geometry',stylers:[{color:'#f5c842'}]},
  {featureType:'road.highway',elementType:'geometry.stroke',stylers:[{color:'#e0b030'}]},
  {featureType:'road.local',elementType:'labels.text.fill',stylers:[{color:'#5a7060'}]},
  {featureType:'transit.line',elementType:'geometry',stylers:[{color:'#c5b89a'}]},
  {featureType:'water',elementType:'geometry.fill',stylers:[{color:'#8ab4c8'}]},
  {featureType:'water',elementType:'labels.text.fill',stylers:[{color:'#1d4060'}]},
  {featureType:'poi',elementType:'labels',stylers:[{visibility:'off'}]}
];

const LM_PIN = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="40" viewBox="0 0 32 40"><path d="M16 0C7.163 0 0 7.163 0 16c0 10 16 24 16 24s16-14 16-24C32 7.163 24.837 0 16 0z" fill="#1d6b40"/><circle cx="16" cy="16" r="7" fill="#f5c842"/></svg>`;
const LM_PIN_ACTIVE = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="40" viewBox="0 0 32 40"><path d="M16 0C7.163 0 0 7.163 0 16c0 10 16 24 16 24s16-14 16-24C32 7.163 24.837 0 16 0z" fill="#134d2d"/><circle cx="16" cy="16" r="7" fill="#f5c842"/></svg>`;

let lmMap, lmGeocoder, lmInfoWindow;
let lmMarkers = [];
let lmFiltered = [...LM_STORES];
let lmUserLat = null, lmUserLng = null;

function lmDist(lat1,lng1,lat2,lng2){const R=6371,dLat=(lat2-lat1)*Math.PI/180,dLng=(lng2-lng1)*Math.PI/180,a=Math.sin(dLat/2)**2+Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLng/2)**2;return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));}
function lmUrl(s){return`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(s.address+', '+s.city+', Nederland')}`;}
function lmIcon(active){return{url:'data:image/svg+xml;charset=UTF-8,'+encodeURIComponent(active?LM_PIN_ACTIVE:LM_PIN),scaledSize:new google.maps.Size(active?34:28,active?42:35),anchor:new google.maps.Point(active?17:14,active?42:35)};}

function lmRender(stores){
  document.getElementById('lm-count').textContent=`${stores.length} winkels gevonden`;
  document.getElementById('lm-list').innerHTML=stores.length?stores.map((s,i)=>`
    <div class="lm-store-card" data-idx="${i}" onclick="lmSelect(${i})">
      <div class="lm-store-card__name">${s.name}</div>
      <div class="lm-store-card__address">${s.address}, ${s.city}</div>
      <div class="lm-store-card__footer">
        ${s.distance!==undefined?`<span class="lm-store-card__distance">${s.distance.toFixed(1)} km</span>`:'<span></span>'}
        <a class="lm-store-card__directions" href="${lmUrl(s)}" target="_blank" onclick="event.stopPropagation()">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>Route
        </a>
      </div>
    </div>`).join(''):`<div class="lm-locator__empty">Geen winkels gevonden.<br>Probeer een andere zoekterm.</div>`;
}

function lmSelect(idx){
  const s=lmFiltered[idx];
  document.querySelectorAll('.lm-store-card').forEach(c=>c.classList.remove('active'));
  const card=document.querySelector(`.lm-store-card[data-idx="${idx}"]`);
  if(card){card.classList.add('active');card.scrollIntoView({behavior:'smooth',block:'nearest'});}
  if(!s.lat)return;
  lmMap.panTo({lat:s.lat,lng:s.lng});lmMap.setZoom(15);
  lmMarkers.forEach((m,i)=>{if(m)m.setIcon(lmIcon(i===idx));});
  if(lmInfoWindow)lmInfoWindow.close();
  lmInfoWindow=new google.maps.InfoWindow({content:`<div class="lm-info-window"><strong>${s.name}</strong><span>${s.address}, ${s.city}</span><a href="${lmUrl(s)}" target="_blank">Routebeschrijving</a></div>`});
  if(lmMarkers[idx])lmInfoWindow.open(lmMap,lmMarkers[idx]);
}

function lmUpdateMarkers(){
  lmMarkers.forEach(m=>m&&m.setMap(null));lmMarkers=[];
  lmFiltered.forEach((s,i)=>{
    if(!s.lat)return;
    const m=new google.maps.Marker({position:{lat:s.lat,lng:s.lng},map:lmMap,title:s.name,icon:lmIcon(false)});
    m.addListener('click',()=>lmSelect(i));lmMarkers[i]=m;
  });
}

function lmFilter(q){
  const query=q.toLowerCase().trim();
  lmFiltered=query?LM_STORES.filter(s=>s.city.toLowerCase().includes(query)||s.address.toLowerCase().includes(query)||s.name.toLowerCase().includes(query)):[...LM_STORES];
  if(lmUserLat!==null){lmFiltered.forEach(s=>{if(s.lat)s.distance=lmDist(lmUserLat,lmUserLng,s.lat,s.lng);});lmFiltered.sort((a,b)=>(a.distance||9999)-(b.distance||9999));}
  lmRender(lmFiltered);lmUpdateMarkers();
}

function lmGeocodeAll(){
  let i=0;
  function next(){
    if(i>=LM_STORES.length){lmRender(lmFiltered);lmUpdateMarkers();return;}
    const s=LM_STORES[i];
    if(s.lat){i++;setTimeout(next,10);return;}
    lmGeocoder.geocode({address:`${s.address}, ${s.city}, Nederland`},(res,status)=>{
      if(status==='OK'){s.lat=res[0].geometry.location.lat();s.lng=res[0].geometry.location.lng();}
      i++;setTimeout(next,55);
    });
  }
  next();
}

function lmInitMap(){
  lmGeocoder=new google.maps.Geocoder();
  lmMap=new google.maps.Map(document.getElementById('lm-map'),{
    center:{lat:52.15,lng:5.38},zoom:7,styles:LM_MAP_STYLE,
    mapTypeControl:false,streetViewControl:false,fullscreenControl:false
  });
  lmRender(lmFiltered);
  lmGeocodeAll();
  document.getElementById('lm-search').addEventListener('input',e=>lmFilter(e.target.value));
  document.getElementById('lm-locate').addEventListener('click',()=>{
    if(!navigator.geolocation)return;
    navigator.geolocation.getCurrentPosition(pos=>{
      lmUserLat=pos.coords.latitude;lmUserLng=pos.coords.longitude;
      lmMap.panTo({lat:lmUserLat,lng:lmUserLng});lmMap.setZoom(11);
      new google.maps.Marker({position:{lat:lmUserLat,lng:lmUserLng},map:lmMap,title:'Jouw locatie',
        icon:{url:'data:image/svg+xml;charset=UTF-8,'+encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20"><circle cx="10" cy="10" r="10" fill="#f5c842" opacity=".4"/><circle cx="10" cy="10" r="6" fill="#1d6b40"/><circle cx="10" cy="10" r="3" fill="#f5c842"/></svg>'),scaledSize:new google.maps.Size(20,20),anchor:new google.maps.Point(10,10)}});
      lmFilter(document.getElementById('lm-search').value);
    });
  });
}

(function(){
  const s=document.createElement('script');
  s.src=`https://maps.googleapis.com/maps/api/js?key=${LM_API_KEY}&callback=lmInitMap`;
  s.async=true;s.defer=true;document.head.appendChild(s);
  window.lmInitMap=lmInitMap;
})();
</script>

